# Configuration Django
SECRET_KEY=django-insecure-votre-cle-secrete-ici
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Configuration Base de données (par défaut sqlite3, sinon postgresql)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
# Si PostgreSQL :
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=iai_gestion
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_HOST=db
# DATABASE_PORT=5432

# Configuration CinetPay (Paiement Mobile Money)
# Créez un compte gratuit sur https://www.cinetpay.com pour obtenir vos clés
CINETPAY_API_KEY=votre_api_key_ici
CINETPAY_SITE_ID=votre_site_id_ici
CINETPAY_SECRET_KEY=votre_secret_key_ici
# SANDBOX = mode test (gratuit, sans argent réel) | LIVE = production
CINETPAY_MODE=SANDBOX
# URL publique de votre serveur (nécessaire pour les webhooks CinetPay)
SITE_BASE_URL=http://127.0.0.1:8000

# Configuration Email (Gmail SMTP - gratuit)
# 1. Activer la validation en 2 étapes sur votre compte Google
# 2. Aller sur https://myaccount.google.com/apppasswords
# 3. Créer un "Mot de passe d'application" pour "Courrier"
# 4. Copier le mot de passe généré (16 caractères) ci-dessous
# Si ces variables sont vides, les emails s'affichent dans le terminal (mode dev)
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=admin@iai-cameroun.com
